<screen>
    <view width="100%" height="100%">
        <remove_style_all />
        <style name="overlay" />

        <lv_label
            text="Pairing"
            align="top_mid"
            y="14"
            style_text_font="lv_font_montserrat_48"
        >
            <style name="primary_text" />
        </lv_label>

        <lv_arc
            width="92"
            height="92"
            align="center"
            y="10"
            rotation="270"
            bg_start_angle="0"
            bg_end_angle="360"
            min_value="0"
            max_value="100"
            value="0"
            style_arc_width="10"
            style_arc_width-indicator="10"
            style_arc_color="#pairing_track_color"
            style_arc_color-indicator="#ble_pairing_color"
            style_arc_rounded-indicator="true"
            style_bg_opa="0%"
        />

        <lv_label
            text="30s"
            align="center"
            y="10"
            style_text_font="lv_font_montserrat_22"
        >
            <style name="primary_text" />
        </lv_label>

        <lv_label
            text="#pairing_hint_text"
            align="bottom_mid"
            y="-18"
            style_text_font="lv_font_montserrat_22"
        >
            <style name="secondary_text" />
        </lv_label>
    </view>
</screen>
